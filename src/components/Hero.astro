---
import SocialIcon from "./SocialIcon.astro";

const name = "Hoshino";
const role = "Backend Engineer";
const tagline = "サーバーサイドを中心に、たまにフロントも触ります。";

const socialLinks = [
	{ label: "GitHub", href: "https://github.com/hoshinoooo14-dot", icon: "github" as const },
	{ label: "X", href: "https://x.com/s_primaStella", icon: "x" as const },
	{ label: "Mail", href: "mailto:hoshinoooo14@gmail.com", icon: "mail" as const },
];
---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center">
	<div
		class="pointer-events-none absolute left-1/2 top-1/2 h-[36rem] w-[36rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-br from-indigo-500/30 via-fuchsia-500/20 to-amber-400/20 blur-3xl"
	>
	</div>

	<img
		src="/avatar.jpg"
		alt={name}
		class="relative mb-8 h-44 w-44 rounded-full object-cover object-[75%_25%] shadow-[0_0_60px_-10px_rgba(168,85,247,0.5)] ring-2 ring-neutral-700 sm:h-56 sm:w-56"
	/>
	<h1 class="relative text-5xl font-bold tracking-tight sm:text-6xl">{name}</h1>
	<p class="relative mt-3 text-xl text-neutral-400">{role}</p>
	<p class="relative mt-2 max-w-md text-sm text-neutral-500">{tagline}</p>

	<div class="relative mt-8 flex gap-3">
		{
			socialLinks.map((link) => (
				<a
					href={link.href}
					class="flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/60 px-4 py-2 text-sm text-neutral-400 backdrop-blur transition hover:border-neutral-600 hover:text-neutral-100"
				>
					<SocialIcon name={link.icon} class="h-4 w-4" />
					{link.label}
				</a>
			))
		}
	</div>

	<a
		href="#skills"
		class="relative mt-12 flex flex-col items-center gap-2 text-xs text-neutral-500 transition hover:text-neutral-200"
	>
		scroll
		<span aria-hidden="true" class="animate-bounce">↓</span>
	</a>
</section>
